{
  "name": "aiox-core",
  "version": "1.0.0",
  "description": "CLI para scaffoldar projetos de IA com Claude",
  "main": "src/index.js",
  "bin": {
    "aiox-core": "./bin/aiox-core.js"
  },
  "scripts": {
    "test": "node bin/aiox-core.js --help",
    "pixel-agents": "node scripts/pixel-agents-setup.js",
    "pixel-agents:demo": "node scripts/pixel-agents-setup.js --demo",
    "voice": "bash piranha-squad-ui/start.sh",
    "voice:dev": "NODE_ENV=development bash piranha-squad-ui/start.sh",
    "voice:sonnet": "VOICE_MODEL=claude-sonnet-4-6 bash piranha-squad-ui/start.sh",
    "design:lint": "npx @google/design.md lint DESIGN.md",
    "design:export:tailwind": "npx @google/design.md export --format tailwind DESIGN.md",
    "design:export:dtcg": "npx @google/design.md export --format dtcg DESIGN.md",
    "design:check": "npm run design:lint"
  },
  "keywords": [
    "ai",
    "cli",
    "scaffold",
    "claude",
    "agent"
  ],
  "author": "piranha-global",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "bcryptjs": "^3.0.3",
    "chalk": "4.1.2",
    "commander": "^11.1.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "ora": "5.4.1",
    "prompts": "^2.4.2",
    "twilio": "^5.12.2",
    "ultravox-client": "^0.5.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@google/design.md": "^0.1.1"
  }
}
