# ===================================
# PIRANHA SUPPLIES VOICE — Configuração
# ===================================

# SHOPIFY
SHOPIFY_STORE_URL=sua-loja.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_COLOQUE_AQUI
SHOPIFY_API_VERSION=2024-10

# ULTRAVOX
ULTRAVOX_API_KEY=COLOQUE_AQUI

# TWILIO — Credenciais principais
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=COLOQUE_AQUI

# TWILIO — API Key (região IE1 / Dublin)
# Criar em: console.twilio.com → Account → API Keys & Tokens → Create API Key
# Tipo: Standard  |  Região: Ireland (IE1)
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=COLOQUE_AQUI

# TWILIO — Número e roteamento
TWILIO_FROM_NUMBER=+351COLOQUE_AQUI
TWILIO_EDGE=dublin
TWILIO_REGION=ie1

# VPS / WEBHOOKS
# URL pública da VPS — os webhooks serão:
#   POST https://call.piranhasupplies.com/webhook/twilio/twiml
#   POST https://call.piranhasupplies.com/webhook/twilio/status
VPS_BASE_URL=https://call.piranhasupplies.com
WEBHOOK_PORT=5000
